{
  "name": "@decisionops/dops",
  "version": "0.1.0",
  "description": "dops — repo-anchored CLI for working with decisions",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "dops": "./src/cli.ts"
  },
  "files": ["src", "install"],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "bun run tsc --noEmit",
    "build": "bun build src/cli.ts --compile --outfile dist/dops"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "commander": "^14.0.1",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "signal-exit": "^4.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.24",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.9.2"
  }
}
