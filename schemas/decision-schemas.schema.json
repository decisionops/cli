{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "decision-schemas",
  "description": "Core decision domain enums and base types",
  "$defs": {
    "DecisionStatus": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "enum": [
        "proposed",
        "accepted",
        "deprecated",
        "superseded"
      ]
    },
    "WorkflowDecisionStatus": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "enum": [
        "Proposed",
        "Accepted",
        "Superseded"
      ]
    },
    "DecisionOrigin": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "enum": [
        "manual",
        "agent"
      ]
    },
    "DecisionType": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "enum": [
        "technical",
        "product",
        "business",
        "governance"
      ]
    },
    "DecisionHealth": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "enum": [
        "red",
        "yellow",
        "green",
        "unknown"
      ]
    },
    "GateMode": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "enum": [
        "advisory",
        "soft_block",
        "hard_block"
      ]
    },
    "ConflictResult": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "ConstraintSeverity": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "ProviderKind": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "enum": [
        "openai",
        "anthropic",
        "openai_compatible"
      ]
    },
    "Role": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "enum": [
        "reader",
        "contributor",
        "approver",
        "admin"
      ]
    },
    "Scope": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "repos": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "paths": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "services": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "repos",
        "paths",
        "services",
        "tags"
      ],
      "additionalProperties": false
    },
    "DecisionDocumentFormat": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "const": "tiptap_v1"
    },
    "DecisionIndexingStatus": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "string",
      "enum": [
        "pending",
        "indexed",
        "failed"
      ]
    }
  }
}
